{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "export": "next build",
    "reset:transition-plan-v1": "tsx scripts/reset-transition-plan-v1.mts",
    "cutover:snapshot:create": "tsx scripts/create-transition-cutover-snapshot.mts",
    "cutover:snapshot:restore": "tsx scripts/restore-transition-cutover-snapshot.mts",
    "test:cutover:snapshot": "vitest run scripts/cutover/*.test.ts",
    "test:cutover:snapshot-emulator": "firebase emulators:exec --project demo-transition-cutover --config firebase.cutover-core-test.json --only firestore \"tsx scripts/test-transition-cutover-roundtrip.mts\"",
    "test:rules:transition": "firebase emulators:exec --config firebase.rules-test.json --only firestore \"node scripts/test-transition-rules.mjs\"",
    "test:transition-policy": "tsx scripts/test-transition-policy.ts",
    "test:transition-projections": "tsx scripts/test-transition-projections.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
